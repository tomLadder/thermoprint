{
  "name": "@thermoprint/cli",
  "version": "0.1.0",
  "description": "CLI for Bluetooth thermal printers",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "thermoprint": "src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@stoprocent/noble": "^1.15.0",
    "@thermoprint/core": "workspace:*",
    "@xmldom/xmldom": "^0.8.11",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "jsbarcode": "^3.12.3",
    "ora": "^8.0.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/qrcode": "^1.5.6",
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}
